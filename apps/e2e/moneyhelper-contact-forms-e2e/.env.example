# E2E-only environment overrides for MoneyHelper Contact Forms.
#
# Copy this file to `.env.local` in this folder:
#   cp apps/e2e/moneyhelper-contact-forms-e2e/.env.example apps/e2e/moneyhelper-contact-forms-e2e/.env.local
#
# These values are loaded before the main app `.env.local` when running Playwright webServer.
# Keep only E2E-specific overrides here.

# Mock API - E2E testing
MOCK_API_PORT=4001
MOCK_API_PATH=/mockEndPoint

# Route app API calls to local mock API during E2E
API_URL=http://localhost:${MOCK_API_PORT}${MOCK_API_PATH}
API_CODE=test