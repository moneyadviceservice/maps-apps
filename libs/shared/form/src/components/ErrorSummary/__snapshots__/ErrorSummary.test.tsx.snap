exports[`ErrorSummary renders description if provided 1`] = `
<div
  aria-describedby="error-summary-heading"
  aria-relevant="all"
  data-testid="error-summary-container"
  id="error-summary-container"
  role="alert"
  tabindex="-1"
>
  <div
    class="t-error-summary border-4 w-full border-red-600 py-8 px-4 sm:px-6 lg:px-8 outline-none"
    data-testid="error-records"
