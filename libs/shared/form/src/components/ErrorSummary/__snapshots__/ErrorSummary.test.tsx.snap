      </p>
    </div>
    <div
      class="pl-6"
    >
      <div
        class="flex items-center"
        data-testid="list-element"
      >
        <ul
          class="list-disc ml-4 text-red-600 marker:text-red-600 marker:mr-2 marker:pr-2 space-y-2 marker:leading-snug"
          start="-1"
        >
          <li
            class="underline text-base decoration-solid text-red-600 mb-2.5 last:mb-0 break-words"
          >
            <a
              class="whitespace-pre-wrap"
              data-testid="error-link-0"
              href="#error1"
            >
              Error message 1
            </a>
          </li>
          <li
            class="underline text-base decoration-solid text-red-600 mb-2.5 last:mb-0 break-words"
          >
            <a
