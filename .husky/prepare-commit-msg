#!/bin/sh
. "$(dirname "$0")/conventional-commit-pattern.sh"

COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2

# Only act on git's auto-generated merge commits
if [ "$COMMIT_SOURCE" = "merge" ]; then
    commit_msg=$(head -1 "$COMMIT_MSG_FILE")

    # Skip if message already matches conventional commit format
    if ! echo "$commit_msg" | grep -qE "$CONVENTIONAL_COMMIT_PATTERN"; then
        # Prepend "chore(merge): " to the first line, preserve the rest
        temp_file=$(mktemp)
        {
            echo "chore(repo): $commit_msg"
            tail -n +2 "$COMMIT_MSG_FILE"
        } > "$temp_file"
        mv "$temp_file" "$COMMIT_MSG_FILE"
    fi
fi
